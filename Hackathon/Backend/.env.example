# Professional Hackathon Template Environment Variables

# DATABASE (Postgres/MySQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=hackathon_db

# SECURITY
SECRET_KEY=generate_a_random_string_here_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
